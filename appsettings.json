{
  "Mcp": {
    "Endpoint": "/mcp",
    "Stateless": true
  },
  "Chat": {
    "Endpoint": "/api/chat",
    "Provider": "ollama",
    "DefaultSearchItems": 10,
    "DefaultSearchPage": 1,
    "MaxDataJsonChars": 20000,
    "OpenAI": {
      "BaseUrl": "https://api.openai.com/v1/",
      "ApiKey": "",
      "Model": "gpt-4.1-mini",
      "TimeoutSeconds": 60
    },
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "Model": "llama3.1:8b",
      "TimeoutSeconds": 120,
      "UseJsonFormat": true
    }
  },
  "CamaraApi": {
    "BaseUrl": "https://dadosabertos.camara.leg.br/api/v2/",
    "TimeoutSeconds": 30,
    "CacheSqlitePath": "",
    "CacheTtlMinutes": 60
  },
  "Cors": {
    "AllowAnyOrigin": true,
    "AllowedOrigins": [],
    "ExposedHeaders": [
      "Mcp-Session-Id"
    ]
  }
}
